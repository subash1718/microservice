server:
  port: 8080

spring:
  application:
    name: api-gateway

  cloud:
    gateway:
      routes:
        - id: order-service
          uri: http://order-service:8082
          predicates:
            - Path=/orders/**

eureka:
  client:
    service-url:
      defaultZone: http://eureka-server:8761/eureka
